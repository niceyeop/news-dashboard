[Unit]
Description=News Dashboard (Streamlit)
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/news-dashboard
EnvironmentFile=/opt/news-dashboard/.env
ExecStart=/opt/news-dashboard/.venv/bin/streamlit run app.py --server.address 0.0.0.0 --server.port 8501
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
